# ==================== BASE DE DATOS ====================
# PostgreSQL Configuration
DB_NAME=certificados_db
DB_USER=certificados_user
DB_PASSWORD=secure_password_here
DB_HOST=localhost
DB_PORT=5432

# ==================== DJANGO ====================
# Generar una con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-django-secret-key-here

# DEBUG: True para desarrollo, False para producción
DEBUG=True

# ==================== EMAIL CONFIGURATION ====================
# Gmail SMTP Configuration
# IMPORTANTE: Usar App Password, NO la contraseña normal
# Obtener App Password: Google Account → Security → App passwords

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail-account@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-16-chars
DEFAULT_FROM_EMAIL=your-gmail-account@gmail.com

# ==================== TWILIO CONFIGURATION ====================
# WhatsApp Integration via Twilio
# Obtener credenciales en: https://console.twilio.com

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxXXX
TWILIO_PHONE_NUMBER=+1234567890

# ==================== CERTIFICADOS ====================
# Días hasta que un certificado expire
CERTIFICATE_EXPIRY_DAYS=365

# Habilitar verificación de certificados
CERTIFICATE_VERIFICATION_ENABLED=True

# ==================== PRODUCCIÓN (Opcional) ====================
# Descomentar estas líneas solo en producción

# ALLOWED_HOSTS=tudominio.com,www.tudominio.com
# CSRF_TRUSTED_ORIGINS=https://tudominio.com
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_SSL_REDIRECT=True
